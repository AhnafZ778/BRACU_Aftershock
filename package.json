{
  "name": "nirapotta",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=20.19.0",
    "npm": ">=10"
  },
  "scripts": {
    "dev": "concurrently --kill-others-on-fail --names FRONTEND,BACKEND,HARVESTER --prefix-colors cyan,green,magenta \"npm run dev:frontend\" \"npm run dev:backend:win\" \"npm run dev:harvester\"",
    "dev:frontend": "vite",
    "dev:backend:auto": "bash ./backend/scripts/dev_backend.sh",
    "dev:harvester:auto": "bash ./backend/scripts/dev_harvester.sh",
    "dev:backend": "cd backend && venv/bin/python -m uvicorn main:app --reload --port 8001",
    "dev:backend:unix": "cd backend && venv/bin/python -m uvicorn main:app --reload --port 8001",
    "dev:backend:win": "cd backend && venv\\Scripts\\python -m uvicorn main:app --reload --port 8001",
    "dev:harvester": "cd backend && venv\\Scripts\\python harvester.py",
    "dev:harvester:unix": "cd backend && venv/bin/python harvester.py",
    "dev:backend:local": "cd backend && ./venv/bin/python3 -m uvicorn main:app --reload --port 8001",
    "dev:harvester:local": "cd backend && ./venv/bin/python3 harvester.py",
    "test:chatbot": "node scripts/chatbot_quality_check.mjs",
    "check:memory:backend": "backend/venv/bin/python scripts/memory_gate_backend.py",
    "check:memory:backend:strict": "MEMORY_GATE_IDLE_SECONDS=600 backend/venv/bin/python scripts/memory_gate_backend.py",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "quality:honeycomb": "python3 tools/honeycomb_quality_gate.py",
    "formula:reconcile": "python3 tools/honeycomb_formula_reconciliation.py",
    "formula:snapshot": "python3 tools/honeycomb_formula_snapshot.py",
    "formula:snapshot:update": "python3 tools/honeycomb_formula_snapshot.py --write",
    "audit:underestimation": "python3 tools/honeycomb_underestimation_audit.py",
    "preview": "vite preview"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@turf/turf": "^7.3.4",
    "@types/leaflet": "^1.9.21",
    "@types/leaflet-routing-machine": "^3.2.9",
    "@types/leaflet.markercluster": "^1.5.6",
    "@types/three": "^0.183.1",
    "clsx": "^2.1.1",
    "concurrently": "^9.2.1",
    "framer-motion": "^12.36.0",
    "leaflet": "^1.9.4",
    "leaflet-routing-machine": "^3.2.12",
    "leaflet.heat": "^0.2.0",
    "leaflet.markercluster": "^1.5.3",
    "lucide-react": "^0.577.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-leaflet": "^5.0.0",
    "react-leaflet-cluster": "^4.0.0",
    "react-leaflet-markercluster": "^5.0.0-rc.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.13.1",
    "svg-path-properties": "^2.0.2",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "three": "^0.183.2",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.58.2",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.3.1"
  }
}
